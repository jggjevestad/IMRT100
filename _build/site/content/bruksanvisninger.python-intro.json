s23fUKK"}],"identifier":"skript-1-omregning-av-vinkelm-l","label":"Skript 1: Omregning av Vinkelmål","html_id":"skript-1-omregning-av-vinkelm-l","implicit":true,"key":"kzCq2whrZp"},{"type":"paragraph","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"text","value":"Kopier denne koden inn i en fil kalt ","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"zYQonjjlRM"},{"type":"inlineCode","value":"vinkler.py","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"PS45LCmv7a"},{"type":"text","value":". Den konverterer mellom grader, radianer og gon (nygrader).","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"wTaIPsTlIN"}],"key":"FqZW7TjjoD"},{"type":"code","lang":"python","value":"from numpy import pi\n\ndef deg2rad(deg):\n    return deg * (pi / 180.0)\n\ndef rad2deg(rad):\n    return rad * (180.0 / pi)\n\ndef gon2deg(gon):\n    return gon * (360.0 / 400.0)\n\ndef deg2gon(deg):\n    return deg * (400.0 / 360.0)\n\n# --- Test av vinkelomregning ---\nvinkel_deg = 90.0\nvinkel_rad = deg2rad(vinkel_deg)\nvinkel_gon = deg2gon(vinkel_deg)\n\nprint(\"=== Vinkelomregning ===\")\nprint(f\"{vinkel_deg:.4f} grader  =  {vinkel_rad:.7f} radianer\")\nprint(f\"{vinkel_deg:.4f} grader  =  {vinkel_gon:.4f} gon\")","position":{"start":{"line":79,"column":1},"end":{"line":102,"column":1}},"key":"HdocEMgcFe"},{"type":"thematicBreak","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"key":"kowzPd0EdB"},{"type":"heading","depth":3,"position":{"start":{"line":106,"column":1},"end":{"line":106,"column":1}},"children":[{"type":"text","value":"Skript 2: Gjennomsnitt og Standardavvik fra CSV","position":{"start":{"line":106,"column":1},"end":{"line":106,"column":1}},"key":"GAjAHZ0SJ6"}],"identifier":"skript-2-gjennomsnitt-og-standardavvik-fra-csv","label":"Skript 2: Gjennomsnitt og Standardavvik fra CSV","html_id":"skript-2-gjennomsnitt-og-standardavvik-fra-csv","implicit":true,"key":"iUCZIHJ3pw"},{"type":"paragraph","position":{"start":{"line":107,"column":1},"end":{"line":108,"column":1}},"children":[{"type":"text","value":"Dette skriptet leser en CSV-fil med koordinater (f.eks. eksportert fra QGIS i UTM-meter) og regner ut gjennomsnitt og standardavvik for X (Øst) og Y (Nord).\nLagre koden som ","position":{"start":{"line":107,"column":1},"end":{"line":107,"column":1}},"key":"k2g4mNHAHW"},{"type":"inlineCode","value":"beregn_snitt.py","position":{"start":{"line":107,"column":1},"end":{"line":107,"column":1}},"key":"SC3rk0nuhc"},{"type":"text","value":" i samme mappe som koordinatfilen din (","position":{"start":{"line":107,"column":1},"end":{"line":107,"column":1}},"key":"NQhMiOA0M6"},{"type":"inlineCode","value":"data.csv","position":{"start":{"line":107,"column":1},"end":{"line":107,"column":1}},"key":"Fzd0ajfhJe"},{"type":"text","value":").","position":{"start":{"line":107,"column":1},"end":{"line":107,"column":1}},"key":"i0iV0CiEsr"}],"key":"Y9CyvIfYig"},{"type":"code","lang":"python","value":"import csv\nimport numpy as np\n\n# --- Konfigurasjon ---\ncsv_file = 'data.csv'   # Navn på CSV-filen din\neasting_col = 0         # Kolonneindeks for X/Øst (0 betyr første kolonne)\nnorthing_col = 1        # Kolonneindeks for Y/Nord (1 betyr andre kolonne)\n\ndef analyser_koordinater(filnavn):\n    ost_verdier = []\n    nord_verdier = []\n    \n    with open(filnavn, 'r') as fil:\n        leser = csv.reader(fil)\n        header = next(leser)  # Hopper over første rad med kolonnenavn\n        \n        for rad in leser:\n            try:\n                # Konverterer tekstverdiene til flyttall (float)\n                ost_verdier.append(float(rad[easting_col]))\n                nord_verdier.append(float(rad[northing_col]))\n            except ValueError:\n                # Hopper over eventuelle rader med tekstfeil\n                continue\n                \n    # Gjør om listene til NumPy-arrays for raskere beregning\n    ost_array = np.array(ost_verdier)\n    nord_array = np.array(nord_verdier)\n    \n    # Beregner statistikk\n    snitt_ost = np.mean(ost_array)\n    snitt_nord = np.mean(nord_array)\n    std_ost = np.std(ost_array, ddof=1)  # ddof=1 gir utvalgs-standardavvik\n    std_nord = np.std(nord_array, ddof=1)\n    \n    return snitt_ost, snitt_nord, std_ost, std_nord\n\n# --- Kjøring ---\ntry:\n    snitt_x, snitt_y, avvik_x, avvik_y = analyser_koordinater(csv_file)\n    print(\"=== Posisjonsstatistikk ===\")\n    print(f\"Målinger analysert fra: {csv_file}\")\n    print(f\"Gjennomsnitt  -  Øst (X): {snitt_x:.3f} m   Nord (Y): {snitt_y:.3f} m\")\n    print(f\"Standardavvik -  Øst (X): {avvik_x:.3f} m   Nord (Y): {avvik_y:.3f} m\")\nexcept FileNotFoundError:\n    print(f\"Feil: Fant ikke filen '{csv_file}'. Sjekk at skriptet ligger i samme mappe.\")","position":{"start":{"line":109,"column":1},"end":{"line":156,"column":1}},"key":"bEsIJHe0zC"},{"type":"thematicBreak","position":{"start":{"line":158,"column":1},"end":{"line":158,"column":1}},"key":"GcOPS6oNJI"},{"type":"heading","depth":2,"position":{"start":{"line":160,"column":1},"end":{"line":160,"column":1}},"children":[{"type":"text","value":"💡 Tips & feilsøking","position":{"start":{"line":160,"column":1},"end":{"line":160,"column":1}},"key":"PKGyrawsqQ"}],"identifier":"id-tips-feils-king","label":"💡 Tips & feilsøking","html_id":"id-tips-feils-king","implicit":true,"key":"VRr0xiW8yG"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":162,"column":1},"end":{"line":164,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":162,"column":1},"end":{"line":162,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":162,"column":1},"end":{"line":162,"column":1}},"children":[{"type":"text","value":"🚨 ","position":{"start":{"line":162,"column":1},"end":{"line":162,"column":1}},"key":"NuOT96mWvl"},{"type":"inlineC